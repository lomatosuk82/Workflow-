<p>Returns</p></th>
<th style=3D"text-align: left;" class=3D"confluenceTh">
<p>Meaning</p></th>
<th style=3D"text-align: left;" class=3D"confluenceTh">
<p>Availability</p></th>
<th colspan=3D"1" class=3D"confluenceTh"><span class=3D"legacy-color-text-b=
lue1">Available in ADW</span></th>
</tr>
<tr>
<td style=3D"text-align: left;" class=3D"confluenceTd">
<p>ID</p></td>
<td style=3D"text-align: left;" class=3D"confluenceTd">
<p>Integer</p></td>
<td style=3D"text-align: left;" class=3D"confluenceTd">
<p>Internal supplier ID</p></td>
<td style=3D"text-align: left;" class=3D"confluenceTd">
<p><br></p></td>
