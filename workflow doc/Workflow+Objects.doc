&lt;StepRef name=3D"Replenishment Flag is True" /&gt;<br>
&lt;FolderRef name=3D"Replenishment Check" /&gt;<br>
&lt;Rule&gt;&lt;![CDATA[[DocLine.Replenishment=3Dtrue]]]&gt;&lt;/Rule&gt;<b=
r>
&lt;FolderSelectionRule&gt;ExplicitFolder&lt;/FolderSelectionRule&gt;<br>
&lt;Attribute name=3D"wfActivityHelp"&gt;<br>
&lt;AttrValue lang=3D"default"&gt;Replenishment Flag is True&lt;/AttrValue&=
gt;<br>
&lt;/Attribute&gt;<br>
&lt;/Activity&gt;</p></td>
<td colspan=3D"1" class=3D"confluenceTd">
<p>19.1.20190530</p>
<p>19.2</p></td>
<td colspan=3D"1" style=3D"text-align: center;" class=3D"confluenceTd">X</t=
d>
</tr>
</tbody>
</table>
</div>
