<tr data-local-id=3D"de8e329a10dd">
<td data-local-id=3D"683a89cda28c" class=3D"confluenceTd">
<p local-id=3D"a7b61edc4456">610</p></td>
<td data-local-id=3D"506a4dfbbaa3" class=3D"confluenceTd">
<p local-id=3D"b26ef48f3b3a">DelayWorkflowRobot</p></td>
<td data-local-id=3D"9000f8956c54" class=3D"confluenceTd">
<p local-id=3D"ee7c4ddd8a06">Adding this robot to a workflow pauses the wor=
kflow process for a configured number of minutes before it moves to next st=
ep.</p></td>
<td data-local-id=3D"8116ed0c6ec8" class=3D"confluenceTd">
<p local-id=3D"1b62908143c5">&lt;Attribute name=3D"wfDelayTimerThreshold"&g=
t;<br>
&lt;AttrValue lang=3D"default"&gt;5&lt;/AttrValue&gt;<br>
&lt;/Attribute&gt;</p></td>
</tr>
<tr data-local-id=3D"492983586ac6">
