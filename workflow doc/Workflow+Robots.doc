<table data-table-width=3D"1776.9042" data-layout=3D"full-width" data-local=
-id=3D"c7deb730-52b3-400c-8884-610cfe56e292" class=3D"confluenceTable">
<colgroup>
<col style=3D"width: 241.74px;">
<col style=3D"width: 522.81px;">
