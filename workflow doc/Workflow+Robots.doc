<tr data-local-id=3D"662262635262">
<td data-local-id=3D"3783b139e1cd" class=3D"confluenceTd">
<p local-id=3D"8e05751a9f41">726</p></td>
<td data-local-id=3D"e26b28a906c1" class=3D"confluenceTd">
<p local-id=3D"9bf045b3aeab">AddPaymentsToBatchRobot</p></td>
<td data-local-id=3D"ae308c33368e" class=3D"confluenceTd">
<p local-id=3D"4429a05ba5d6">AddPaymentsToBatchRobot successfully automatic=
ally adds Payment to Batch when all of the following criteria are met:</p>
<ul local-id=3D"7e753cda4d24">
<li local-id=3D"83a16e99bbfc">
<p local-id=3D"edf8f3e3aeee">Payment is in Payable status</p></li>
<li local-id=3D"a641d34889ca">
<p local-id=3D"e3c60e2d367a">Payment Processor supports batch integration</=
p></li>
<li local-id=3D"dc5a9052b1d4">
<p local-id=3D"2407fe4bc030">Payment is not already assigned to a batch</p>=
</li>
<li local-id=3D"0b7a4b9a0d0f">
<p local-id=3D"a80683f5d733">Batch is in Pending status</p></li>
<li local-id=3D"1c16e2fe64b3">
<p local-id=3D"f8620492bcba">Batch has less than 500 payments</p></li>
<li local-id=3D"b36098807dd2">
<p local-id=3D"25a7289179d6">Batch currency matches Payment currency</p></l=
i>
<li local-id=3D"2ef244298402">
<p local-id=3D"ae7b88036f15">Batch processor type matches Payment processor=
 type</p></li>
<li local-id=3D"b4646663f1de">
<p local-id=3D"fa9f67e47de9">One of the following is true:</p>
<ul local-id=3D"7bc2df14f726">
<li local-id=3D"7d81bb999693">
<p local-id=3D"8f2d0d33597f">Batch is Open Connect</p></li>
<li local-id=3D"1bbccd6a10b5">
<p local-id=3D"80cf1d1651e8">Batch Process Date is on or after Payment Due =
Date, which is in the future</p></li>
<li local-id=3D"83e139041840">
<p local-id=3D"6ec489243639">Payment has no Due Date</p></li>
</ul></li>
</ul></td>
<td data-local-id=3D"0e24b85a2b93" class=3D"confluenceTd">
<p local-id=3D"289bb29513e2">Workflow robot:</p><span class=3D"confluence-e=
